<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true"
    tools:context=".activities.DiceRollActivity">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingLeft="32dp"
    android:paddingTop="72dp"
    android:paddingRight="32dp"
    android:paddingBottom="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/dice_selection_panel_background"
        android:orientation="horizontal">

        <Spinner
            android:id="@+id/spinnerDice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:entries="@array/dice_options" />

        <EditText
            android:id="@+id/inputCustomSides"
            android:layout_width="96dp"
            android:layout_height="wrap_content"
            android:hint="Sides"
            android:inputType="number"
            android:maxLength="4" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtDiceVisual"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:background="@drawable/dice_result_background"
        android:gravity="center"
        android:text="-"
        android:textColor="@color/text_primary"
        android:textSize="52sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtResult"
        style="@style/BodyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Choose a die and roll." />

    <Button
        android:id="@+id/btnRoll"
        style="@style/PrimaryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Roll" />

    <Button
        android:id="@+id/btnClearHistory"
        style="@style/PrimaryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Clear History" />

    <Switch
        android:id="@+id/switchVibration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:checked="true"
        android:text="Vibration" />

    <TextView
        style="@style/TitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Roll History" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRollHistory"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="8dp"
        android:nestedScrollingEnabled="false" />

</LinearLayout>
</ScrollView>
